# =============================================================
# VARIÁVEIS DE AMBIENTE — Vantrack Backend
# =============================================================
# Para usar: Copie este arquivo para .env e preencha os valores
# não compartilhe credenciais reais no repositório

# Database# Configurações de Produção Vantrack
FLASK_ENV=production
FLASK_DEBUG=False
JWT_SECRET=SubstituaEstaChavePorUmaMuitoLongaERandomicaEmProducao!!

# Banco de Dados
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=senha_segura_do_mysql
DB_NAME=vantrack

# SMTP (Email 2FA)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email-aqui@gmail.com
SMTP_PASSWORD=sua-senha-de-appeta-aqui-min-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Application Settings
API_PORT=5000
API_HOST=0.0.0.0
